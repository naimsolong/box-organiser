# Public site URL used to build QR code links. In production, set this to your
# deployed domain (e.g. https://box-organiser.<account>.workers.dev).
# Leave empty to build QR links from the request origin.
NUXT_PUBLIC_SITE_URL=

# Better Auth session secret. Generate one with: openssl rand -base64 32
# For local dev, a default is provided via wrangler.jsonc `vars`.
# For production, set it as a secret: wrangler secret put BETTER_AUTH_SECRET
BETTER_AUTH_SECRET=
