# Auth mode is selected automatically from NUXT_PUBLIC_SITE_URL:
#   - localhost / 127.0.0.1 -> email + password (local dev, no Google setup)
#   - any other URL          -> Google SSO only (production)
#
# Required in BOTH dev and production:
#   NUXT_PUBLIC_SITE_URL  - origin used for QR codes + OAuth callback base
#   BETTER_AUTH_SECRET    - session signing secret (generate: openssl rand -base64 32)
#
# Required in PRODUCTION ONLY (set via `wrangler secret put`):
#   GOOGLE_CLIENT_ID      - from Google Cloud Console OAuth client
#   GOOGLE_CLIENT_SECRET  - from Google Cloud Console OAuth client

# Public site URL used to build QR code links and to detect auth mode.
# Dev:    http://localhost:3000
# Prod:   https://<your-prod-domain>
NUXT_PUBLIC_SITE_URL=

# Better Auth session secret. Generate one with: openssl rand -base64 32
# Dev:    copy to .dev.vars (gitignored)
# Prod:   wrangler secret put BETTER_AUTH_SECRET
BETTER_AUTH_SECRET=

# Google OAuth client credentials (production only).
# Dev:    leave blank — email/password is used in dev.
# Prod:   wrangler secret put GOOGLE_CLIENT_ID
#         wrangler secret put GOOGLE_CLIENT_SECRET
# Get them at: https://console.cloud.google.com/ -> APIs & Services -> Credentials
# Authorized redirect URI must be: ${NUXT_PUBLIC_SITE_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
